// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  qualification QualificationLevel?
  
  // Personal Details
  firstName     String?
  middleName    String?
  lastName      String?
  dob           DateTime?
  address       String?

  // Educational Details
  tenthSchool   String?
  tenthPercent  Float?

  twelfthSchool String? // Also covers "College" for 12th if applicable
  twelfthCollege String? // Explicit field as requested
  twelfthPercent Float?

  ugCollege     String?
  ugUniversity  String?
  ugPercent     Float?

  pgCollege     String?
  pgUniversity  String?
  pgPercent     Float?
  
  // Documents (URLs or paths)
  marksheet10thUrl        String?
  marksheet12thUrl        String?
  resumeUrl               String?
  highestQualMarksheetUrl String? // For UG/PG

  skills String? // Comma separated for simple matching logic
  
  applications Application[]
}

enum QualificationLevel {
  TENTH
  TWELFTH
  UG
  PG
}

model Job {
  id          String   @id @default(uuid())
  title       String
  description String
  company     String
  location    String
  salary      String?
  type        String   @default("Full-time")
  category    String   @default("Private") // "Government" or "Private"
  minQualification QualificationLevel @default(TENTH)
  
  requiredSkills String? // Comma separated for simple matching logic

  createdAt DateTime @default(now())
  
  applications Application[]
}

model Application {
  id        String   @id @default(uuid())
  userId    String
  jobId     String
  status    String   @default("PENDING") // PENDING, ACCEPTED, REJECTED
  appliedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  job  Job  @relation(fields: [jobId], references: [id])
}
