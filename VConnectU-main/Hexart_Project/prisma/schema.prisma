// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("USER") // "USER" or "HR"
  resetToken       String?
  resetTokenExpiry DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  qualification QualificationLevel?
  
  // Personal Details
  firstName     String?
  middleName    String?
  lastName      String?
  dob           DateTime?
  address       String?

  // Educational Details
  tenthSchool   String?
  tenthPercent  Float?

  twelfthSchool String? // Also covers "College" for 12th if applicable
  twelfthCollege String? // Explicit field as requested
  twelfthPercent Float?

  ugCollege     String?
  ugUniversity  String?
  ugPercent     Float?

  pgCollege     String?
  pgUniversity  String?
  pgPercent     Float?
  
  // Documents (URLs or paths)
  marksheet10thUrl        String?
  marksheet12thUrl        String?
  resumeUrl               String?
  highestQualMarksheetUrl String? // For UG/PG

  skills String? // Comma separated for simple matching logic
  
  // SkillVouch Integration Fields
  bio              String?
  avatar           String?
  phone            String?
  discordLink      String?
  rating           Float    @default(0.0)
  learningHours    Int      @default(0)
  weeklyActivity   Int      @default(0)
  skillsKnown      String?  // JSON string
  skillsToLearn    String?  // JSON string
  
  applications Application[]
  ideas        Idea[]

  quizzes             SkillQuiz[]
  sentRequests        ExchangeRequest[] @relation("RequestSender")
  receivedRequests    ExchangeRequest[] @relation("RequestReceiver")
  sentFeedback        ExchangeFeedback[] @relation("FeedbackSender")
  receivedFeedback    ExchangeFeedback[] @relation("FeedbackReceiver")
  sentMessages        Message[] @relation("MessageSender")
  receivedMessages    Message[] @relation("MessageReceiver")
}

model SkillQuiz {
  id            String   @id @default(uuid())
  userId        String
  skillName     String
  difficulty    String   @default("beginner") // 'beginner', 'intermediate', 'advanced'
  questions     String   // JSON string storing questions
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([userId, skillName])
  @@index([userId])
  @@index([skillName])
}

model ExchangeRequest {
  id             String   @id @default(uuid())
  fromUserId     String
  toUserId       String
  offeredSkill   String
  requestedSkill String
  message        String?
  status         String   @default("pending") // 'pending', 'accepted', 'rejected', 'completed'
  createdAt      DateTime @default(now())
  completedAt    DateTime?
  
  fromUser       User     @relation("RequestSender", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser         User     @relation("RequestReceiver", fields: [toUserId], references: [id], onDelete: Cascade)
}

model ExchangeFeedback {
  id          String   @id @default(uuid())
  requestId   String
  fromUserId  String
  toUserId    String
  stars       Int
  comment     String?
  createdAt   DateTime @default(now())
  
  fromUser    User     @relation("FeedbackSender", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser      User     @relation("FeedbackReceiver", fields: [toUserId], references: [id], onDelete: Cascade)
}

model Message {
  id          String   @id @default(uuid())
  senderId    String
  receiverId  String
  content     String
  timestamp   DateTime @default(now())
  read        Boolean  @default(false)
  
  sender      User     @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver    User     @relation("MessageReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
}


enum QualificationLevel {
  TENTH
  TWELFTH
  UG
  PG
}

model Job {
  id          String   @id @default(uuid())
  title       String
  description String
  company     String
  location    String
  salary      String?
  type        String   @default("Full-time")
  category    String   @default("Private") // "Government" or "Private"
  minQualification QualificationLevel @default(TENTH)
  
  requiredSkills String? // Comma separated for simple matching logic
  deadline       DateTime?
  
  selectionProcessString String? // e.g. "CBT -> PET -> Medical"
  examDate             DateTime?
  examMode             String?   // "Online" or "Offline"
  link                 String?   // URL to the official job posting

  createdAt DateTime @default(now())
  
  applications Application[]
}

model Application {
  id        String   @id @default(uuid())
  userId    String
  jobId     String
  status    String   @default("PENDING") // PENDING, ACCEPTED, REJECTED
  appliedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  job  Job  @relation(fields: [jobId], references: [id])
}

model Competition {
  id          String   @id @default(uuid())
  title       String
  platform    String   // e.g., LeetCode, CodeChef, HackerRank
  description String?
  link        String
  prize       String?  // e.g., "Internship Opportunity", "$100", "Certificates"
  deadline    DateTime?
  startDate   DateTime?
  type        String   // e.g., "Coding Contest", "Hackathon", "Hiring Challenge"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ResearchPaper {
  id          String   @id @default(uuid())
  title       String
  publisher   String   // e.g., IEEE, ACM, Nature
  conference  String?  // e.g., ICML, NeurIPS
  description String?
  link        String
  deadline    DateTime?
  topic       String?  // e.g., AI, Blockchain, Biology
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Idea {
  id           String   @id @default(uuid())
  title        String
  problem      String
  solution     String
  technologies String // Comma separated
  impact       String
  contactEmail String
  contactPhone String
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
